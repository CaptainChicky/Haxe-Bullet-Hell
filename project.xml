<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="BulletHell" package="me.theaviary.BulletHell" version="1.0.0" company="CCP" />

	<!-- Added app configuration -->
	<app main="Main" path="Export" file="BulletHell"></app>

	<source path="Source" />

	<haxelib name="openfl" />

	<assets path="Assets" rename="assets" />

	<!-- The *logical* stage size, not a window size: Main sets
	     StageScaleMode.SHOW_ALL, so OpenFL scales this to whatever the real
	     window is and stage dimensions stay 1920x1080 everywhere. 16:9 is
	     chosen so it fills a modern display exactly, with no letterbox bars.
	     The 1800x1080 playfield that levels are authored against sits centred
	     inside it — see DisplaySettings.FIELD_W / FIELD_X. Must stay in sync
	     with DisplaySettings.LOGICAL_W / LOGICAL_H.
	     Native targets default to 30 fps unless set explicitly; the game logic
	     is frame-based and tuned for 60. -->
	<window width="1920" height="1080" fps="60" hardware="true" antialiasing="0" />

	<!-- Deliberately NOT fullscreen="true": lime maps that to a real SDL
	     exclusive-fullscreen display-mode switch, which is not composited, so
	     Win+Shift+S captures a stale frame (this is why fullscreen screenshots
	     showed the previous windowed contents). DisplaySettings instead fakes
	     fullscreen at runtime with borderless + resize-to-display-bounds, which
	     looks identical and stays capturable.
	     Created borderless because the default mode is fullscreen and lime's
	     runtime `window.borderless` setter does not reliably drop an existing
	     title bar; windowed mode restores the border at runtime, which is the
	     direction that does work. -->
	<window if="windows" borderless="true" resizable="true" vsync="true" />

	<!-- Without this, Stage.__resize() sizes the GL back buffer to the *logical*
	     size (1800x1080) while the viewport is the real window (e.g. 1920x1080).
	     The mismatch clips the right edge and leaves an uncleared strip — the
	     "squished, white bar on the right" symptom. openfl_dpi_aware makes the
	     back buffer track the window instead. See openfl/display/Stage.hx:3175. -->
	<haxedef name="openfl_dpi_aware" />

	<!-- Strip trace() calls from release builds; per-hit traces are a real
	     per-frame cost on native. -->
	<haxeflag name="--no-traces" unless="debug" />
</project>
