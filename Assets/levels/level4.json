{
  "name": "Stage 4 - The Gilded Court",
  "dialogue": {
    "intro": [
      {
        "speaker": "Aviator",
        "text": "The signal jamming, the swarms, the fire... it all leads here.",
        "portrait": "assets/Player.png",
        "side": "left"
      },
      {
        "speaker": "???",
        "text": "And here you are, little bird, at the doors of my court.",
        "portrait": "assets/Enemy(second).png",
        "side": "right"
      },
      {
        "speaker": "Aurelia",
        "text": "I am Aurelia, Queen of the Aviary. Every wing in this sky beats at MY command.",
        "portrait": "assets/Enemy(second).png",
        "side": "right"
      },
      {
        "speaker": "Aviator",
        "text": "Then I'll just have to clip yours.",
        "portrait": "assets/Player.png",
        "side": "left"
      },
      {
        "speaker": "Aurelia",
        "text": "Bold. Let us see how you dance beneath a thousand wings!",
        "portrait": "assets/Enemy(second).png",
        "side": "right"
      }
    ],
    "outro": [
      {
        "speaker": "Aurelia",
        "text": "My court... my beautiful, gilded court...",
        "portrait": "assets/Enemy(second).png",
        "side": "right"
      },
      {
        "speaker": "Aviator",
        "text": "The sky doesn't belong to anyone. That's what makes it worth flying.",
        "portrait": "assets/Player.png",
        "side": "left"
      },
      {
        "speaker": "Aurelia",
        "text": "Hmph. Then fly, little bird... while I rebuild my choir.",
        "portrait": "assets/Enemy(second).png",
        "side": "right"
      }
    ]
  },
