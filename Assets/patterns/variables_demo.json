{
  "name": "variables_demo",
  "description": "Direction stepped by an incrementing counter variable via Copy+scale",
  "parameters": {
    "speed": {"type": "float", "default": 5},
    "angleStep": {"type": "float", "default": 20},
    "fireDelay": {"type": "int", "default": 4}
  },
  "script": [
    {"control": "Set", "prop": "speed", "value": "$speed"},
    {"control": "Set", "prop": "cnt", "value": 0},
    {
      "control": "Loop",
      "actions": [
        {"control": "Copy", "from": "cnt", "to": "direction", "scale": "$angleStep"},
        {"control": "Fire", "angle": 0, "speed": 0},
        {"control": "Wait", "frames": "$fireDelay"},
        {"control": "Add", "prop": "cnt", "delta": 1}
      ]
    }
  ]
}