{
  "name": "flowerdup",
  "description": "Firedancer flower: the spawn ring carries copies/4 CHUNKS of four 9-way fans each - one arc facing outward at the chunk base, then (trioShift degrees to the right) a trio sharing one spawn point: an arc facing inward plus, above it, a left-facing and a right-facing arc. All bullets decelerate 4->1 over 30 frames (the outward arc rises, the inward arc drives toward/through the enemy, the side arcs slide left/right), hang, then curve 210deg while re-accelerating - the whole lattice twists through away-left/away-right + toward-left/toward-right diagonals, collapses, restores the 1+3 chunks and scatters outward (288 bullets per volley). tangentOffset skews every fan off its cardinal facing",
  "parameters": {
    "copies": {"type": "int", "default": 32, "description": "Total arcs per volley; 4 per chunk (out/in/left/right), so copies/4 chunks ring the circle"},
    "ways": {"type": "int", "default": 9, "description": "NWay fan per arc"},
    "fanArc": {"type": "float", "default": 90, "description": "NWay arc degrees"},
    "bulletSpeed": {"type": "float", "default": 4, "description": "Initial bullet speed"},
    "offsetDist": {"type": "float", "default": 80, "description": "Spawn distance from emitter"},
    "trioShift": {"type": "float", "default": 22.5, "description": "Angular shift (degrees, rightward) from a chunk's outward arc to its in/left/right trio spawn point; half the chunk pitch interleaves the spawn slots evenly"},
    "tangentOffset": {"type": "float", "default": 0, "description": "Extra rotation applied to every fan's facing (0 = clean out/in/left/right cardinals, nonzero = pinwheel skew)"},
    "decelTo": {"type": "float", "default": 1, "description": "Speed after deceleration"},
    "decelFrames": {"type": "int", "default": 30, "description": "Deceleration duration"},
    "curveDeg": {"type": "float", "default": 210, "description": "Direction curve (relative) during petal phase"},
    "curveFrames": {"type": "int", "default": 60, "description": "Petal curve/re-accel duration"},
    "endSpeed": {"type": "float", "default": 2, "description": "Speed after re-acceleration"},
    "volleyDelay": {"type": "int", "default": 240, "description": "Frames between volleys"}
  },
  "script": [
    {
      "control": "Loop", "actions": [
        {"control": "Set", "prop": "speed", "value": "$bulletSpeed"},
        {"control": "Set", "prop": "offsetDistance", "value": "$offsetDist"},
        {"control": "Sub", "actions": [
          {"control": "Tween", "prop": "speed", "to": "$decelTo", "frames": "$decelFrames"},
          {"control": "Concurrent", "share": true, "branches": [
            [{"control": "Tween", "prop": "direction", "to": "$curveDeg", "frames": "$curveFrames", "relative": true}],
            [{"control": "Tween", "prop": "speed", "to": "$endSpeed", "frames": "$curveFrames"}]
          ]}
        ]},
        {"control": "Set", "prop": "cnt", "value": 0},
        {"control": "Scope", "actions": [
          {"control": "Rep", "count": "$copies / 4", "actions": [
            {"control": "Copy", "from": "cnt", "to": "offsetAngle", "scale": "1440 / $copies"},
            {"control": "Copy", "from": "cnt", "to": "direction", "scale": "1440 / $copies"},
            {"control": "Add", "prop": "direction", "delta": "$tangentOffset"},
            {"control": "NWay", "count": "$ways", "angle": "$fanArc", "speed": 0},
            {"control": "Add", "prop": "offsetAngle", "delta": "$trioShift"},
            {"control": "Add", "prop": "direction", "delta": "$trioShift + 180"},
            {"control": "NWay", "count": "$ways", "angle": "$fanArc", "speed": 0},
            {"control": "Add", "prop": "direction", "delta": "-270"},
            {"control": "NWay", "count": "$ways", "angle": "$fanArc", "speed": 0},
            {"control": "Add", "prop": "direction", "delta": "180"},
            {"control": "NWay", "count": "$ways", "angle": "$fanArc", "speed": 0},
            {"control": "Add", "prop": "cnt", "delta": 1}
          ]}
        ]},
        {"control": "Wait", "frames": "$volleyDelay"}
      ]
    }
  ]
}
