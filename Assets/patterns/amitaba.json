{
  "name": "amitaba",
  "description": "Rigid rotating manji (卍) of offset-bound bullets — four hooked arms that hold formation, with a satellite-style laser pod nested in each diagonal gap; the glyph breaks outward when the hold ends",
  "parameters": {
    "armCount": {
      "type": "int",
      "default": 4,
      "description": "Arms of the glyph (4 = a manji)"
    },
    "armBullets": {
      "type": "int",
      "default": 6,
      "description": "Bullets along each straight arm"
    },
    "bendBullets": {
      "type": "int",
      "default": 4,
      "description": "Bullets in each perpendicular hook"
    },
    "spacing": {
      "type": "float",
      "default": 34,
      "description": "Distance between adjacent bullets"
    },
    "handed": {
      "type": "float",
      "default": -1,
      "description": "Hook direction: -1 = 卍, 1 = 卐"
    },
    "baseAngle": {
      "type": "float",
      "default": 0,
      "description": "Starting rotation of the whole glyph"
    },
    "spinStep": {
      "type": "float",
      "default": 0.3,
      "description": "Glyph rotation, degrees per frame (0 = frozen)"
    },
    "holdFrames": {
      "type": "int",
      "default": 260,
      "description": "Frames the glyph holds before breaking apart"
    },
    "releaseSpeed": {
      "type": "float",
      "default": 2.4,
      "description": "Speed each bullet leaves at when the glyph breaks"
    },
    "drawDelay": {
      "type": "int",
      "default": 1,
      "description": "Frames between arms while the glyph inscribes itself"
    },
    "cycleDelay": {
      "type": "int",
      "default": 90,
      "description": "Frames between one glyph and the next"
    },
    "laserRadius": {
      "type": "float",
      "default": 95,
      "description": "Pod distance from center (sits in the gap between arms)"
    },
    "laserCount": {
      "type": "int",
      "default": 5,
      "description": "Bullets per beam"
    },
    "laserGap": {
      "type": "int",
      "default": 3,
      "description": "Frames between beam bullets"
    },
    "laserSpeed": {
      "type": "float",
      "default": 9,
      "description": "Beam bullet speed after spool-up"
    },
    "laserSpool": {
      "type": "int",
      "default": 18,
      "description": "Frames a beam bullet spools up from speed 0"
    },
    "laserCruise": {
      "type": "int",
      "default": 26,
      "description": "Frames a beam bullet flies at full speed"
    },
    "laserBrake": {
      "type": "int",
      "default": 10,
      "description": "Frames a beam bullet takes to brake to a stop"
    },
    "laserHang": {
      "type": "int",
      "default": 26,
      "description": "Frames the stopped column hangs before detonating"
    },
    "laserDelay": {
      "type": "int",
      "default": 60,
      "description": "Frames a pod charges between beams"
    },
    "laserVolleys": {
      "type": "int",
      "default": 2,
      "description": "Beams each pod fires per glyph"
    },
    "burstCount": {
      "type": "int",
      "default": 4,
      "description": "Radial fragments per detonating beam bullet"
    },
    "burstSpeed": {
      "type": "float",
      "default": 2.6,
      "description": "Detonation fragment speed"
    }
  },
  "script": [
    {
      "control": "Set",
      "prop": "speed",
      "value": 0
    },
    {
      "control": "Bind",
      "mode": "offset"
    },
    {
      "control": "SetOffset",
      "distance": 0,
      "angle": 0
    },
    {
      "control": "Loop",
      "actions": [
        {
          "control": "Sub",
          "actions": [
            {
              "control": "Rep",
              "count": "$holdFrames",
              "actions": [
                {
                  "control": "Rotate",
                  "degrees": "$spinStep"
                },
                {
                  "control": "Wait",
                  "frames": 1
                }
              ]
            },
            {
              "control": "Scope",
              "actions": [
                {
                  "control": "Set",
                  "prop": "x",
                  "value": 0
                },
                {
                  "control": "Set",
                  "prop": "y",
                  "value": 0
                },
                {
                  "control": "SetOffset",
                  "distance": 0,
                  "angle": 0
                },
                {
                  "control": "Set",
                  "prop": "speed",
                  "value": "$releaseSpeed"
                },
                {
                  "control": "Set",
                  "prop": "direction",
                  "value": "outAngle + $spinStep * $holdFrames"
                },
                {
                  "control": "Fire",
                  "angle": 0,
                  "speed": 0
                }
              ]
            },
            {
              "control": "Vanish"
            }
          ]
        },
        {
          "control": "Set",
          "prop": "arm",
          "value": 0
        },
        {
          "control": "Rep",
          "count": "$armCount",
          "actions": [
            {
              "control": "Set",
              "prop": "bearing",
              "value": "arm * (360 / $armCount) + $baseAngle"
            },
            {
              "control": "Set",
              "prop": "hookBearing",
              "value": "bearing + 90 * $handed"
            },
            {
              "control": "Set",
              "prop": "outAngle",
              "value": "bearing"
            },
            {
              "control": "Set",
              "prop": "d",
              "value": "$spacing"
            },
            {
              "control": "Rep",
              "count": "$armBullets",
              "actions": [
                {
                  "control": "Set",
                  "prop": "x",
                  "value": "cos(bearing) * d"
                },
                {
                  "control": "Set",
                  "prop": "y",
                  "value": "sin(bearing) * d"
                },
                {
                  "control": "Fire",
                  "angle": 0,
                  "speed": 0
                },
                {
                  "control": "Add",
                  "prop": "d",
                  "delta": "$spacing"
                }
              ]
            },
            {
              "control": "Set",
              "prop": "outAngle",
              "value": "hookBearing"
            },
            {
              "control": "Set",
              "prop": "tipD",
              "value": "$spacing * $armBullets"
            },
            {
              "control": "Set",
              "prop": "e",
              "value": "$spacing"
            },
            {
              "control": "Rep",
              "count": "$bendBullets",
              "actions": [
                {
                  "control": "Set",
                  "prop": "x",
                  "value": "cos(bearing) * tipD + cos(hookBearing) * e"
                },
                {
                  "control": "Set",
                  "prop": "y",
                  "value": "sin(bearing) * tipD + sin(hookBearing) * e"
                },
                {
                  "control": "Fire",
                  "angle": 0,
                  "speed": 0
                },
                {
                  "control": "Add",
                  "prop": "e",
                  "delta": "$spacing"
                }
              ]
            },
            {
              "control": "Add",
              "prop": "arm",
              "delta": 1
            },
            {
              "control": "Wait",
              "frames": "$drawDelay"
            }
          ]
        },
        {
          "control": "Scope",
          "actions": [
            {
              "control": "Set",
              "prop": "x",
              "value": 0
            },
            {
              "control": "Set",
              "prop": "y",
              "value": 0
            },
            {
              "control": "Sub",
              "actions": [
                {
                  "control": "Concurrent",
                  "share": true,
                  "branches": [
                    [
                      {
                        "control": "Rep",
                        "count": "$holdFrames",
                        "actions": [
                          {
                            "control": "AddOffset",
                            "distanceDelta": 0,
                            "angleDelta": "$spinStep"
                          },
                          {
                            "control": "Wait",
                            "frames": 1
                          }
                        ]
                      }
                    ],
                    [
                      {
                        "control": "Rep",
                        "count": "$laserVolleys",
                        "actions": [
                          {
                            "control": "Wait",
                            "frames": "$laserDelay"
                          },
                          {
                            "control": "Scope",
                            "actions": [
                              {
                                "control": "Set",
                                "prop": "direction",
                                "value": "offsetAngle"
                              },
                              {
                                "control": "SetOffset",
                                "distance": 0,
                                "angle": 0
                              },
                              {
                                "control": "Set",
                                "prop": "x",
                                "value": 0
                              },
                              {
                                "control": "Set",
                                "prop": "y",
                                "value": 0
                              },
                              {
                                "control": "Set",
                                "prop": "speed",
                                "value": 0
                              },
                              {
                                "control": "Set",
                                "prop": "fuse",
                                "value": "($laserCount - 1) * $laserGap"
                              },
                              {
                                "control": "Sub",
                                "actions": [
                                  {
                                    "control": "Tween",
                                    "prop": "speed",
                                    "to": "$laserSpeed",
                                    "frames": "$laserSpool"
                                  },
                                  {
                                    "control": "Wait",
                                    "frames": "$laserCruise"
                                  },
                                  {
                                    "control": "Tween",
                                    "prop": "speed",
                                    "to": 0,
                                    "frames": "$laserBrake"
                                  },
                                  {
                                    "control": "Wait",
                                    "frames": "$laserHang"
                                  },
                                  {
                                    "control": "Wait",
                                    "frames": "fuse"
                                  },
                                  {
                                    "control": "Scope",
                                    "actions": [
                                      {
                                        "control": "Set",
                                        "prop": "speed",
                                        "value": "$burstSpeed"
                                      },
                                      {
                                        "control": "Radial",
                                        "count": "$burstCount",
                                        "speed": 0
                                      }
                                    ]
                                  },
                                  {
                                    "control": "Vanish"
                                  }
                                ]
                              },
                              {
                                "control": "Rep",
                                "count": "$laserCount",
                                "actions": [
                                  {
                                    "control": "Fire",
                                    "angle": 0,
                                    "speed": 0
                                  },
                                  {
                                    "control": "Add",
                                    "prop": "fuse",
                                    "delta": "-$laserGap"
                                  },
                                  {
                                    "control": "Wait",
                                    "frames": "$laserGap"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  ]
                },
                {
                  "control": "Vanish"
                }
              ]
            },
            {
              "control": "Set",
              "prop": "pod",
              "value": 0
            },
            {
              "control": "Rep",
              "count": "$armCount",
              "actions": [
                {
                  "control": "SetOffset",
                  "distance": "$laserRadius",
                  "angle": "pod * (360 / $armCount) + 180 / $armCount + $baseAngle"
                },
                {
                  "control": "Fire",
                  "angle": 0,
                  "speed": 0
                },
                {
                  "control": "Add",
                  "prop": "pod",
                  "delta": 1
                }
              ]
            }
          ]
        },
        {
          "control": "Wait",
          "frames": "$holdFrames + $cycleDelay"
        }
      ]
    }
  ]
}
