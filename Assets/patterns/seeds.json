{
  "name": "seeds",
  "description": "Firedancer seeds: alternating top/bottom volleys of decelerating seed bullets; each seed aims at the player and fires a 5-way fan of lineSeed children. The aim direction is captured ONCE at the seed (Copy into the aimDir var, inherited by the children), so all 5 line bursts fire PARALLEL to it - only the center beam passes through the player, the flanking beams run alongside it",
  "parameters": {
    "seedSpeedMin": {"type": "float", "default": 6, "description": "Minimum seed launch speed"},
    "seedSpeedMax": {"type": "float", "default": 9, "description": "Maximum seed launch speed"},
    "seedDecelFrames": {"type": "int", "default": 30, "description": "Seed deceleration duration"},
    "nwayCount": {"type": "int", "default": 5, "description": "Seed burst NWay count"},
    "nwayArc": {"type": "float", "default": 150, "description": "Seed burst NWay arc"},
    "nwaySpeed": {"type": "float", "default": 8, "description": "LineSeed initial speed"},
    "lineCount": {"type": "int", "default": 12, "description": "Bullets per lineSeed burst"},
    "lineSpeedFrom": {"type": "float", "default": 1, "description": "Line speed start"},
    "lineSpeedTo": {"type": "float", "default": 7, "description": "Line speed end"},
    "accelWait": {"type": "int", "default": 15, "description": "Frames before line bullets accelerate"},
    "accelAmount": {"type": "float", "default": 5, "description": "Speed added to line bullets"},
    "accelFrames": {"type": "int", "default": 60, "description": "Acceleration duration"},
    "volleyDelay": {"type": "int", "default": 30, "description": "Frames between volleys"}
  },
  "script": [
    {"control": "Sub", "actions": [
      {"control": "Tween", "prop": "speed", "to": 1, "frames": "$seedDecelFrames"},
      {"control": "Scope", "actions": [
        {"control": "Set", "prop": "speed", "value": "$nwaySpeed"},
        {"control": "AimAtPlayer"},
        {"control": "Copy", "from": "direction", "to": "aimDir"},
        {"control": "Sub", "actions": [
          {"control": "Tween", "prop": "speed", "to": 1, "frames": "$seedDecelFrames"},
          {"control": "Scope", "actions": [
            {"control": "Copy", "from": "aimDir", "to": "direction"},
            {"control": "Sub", "actions": [
              {"control": "Wait", "frames": "$accelWait"},
              {"control": "Tween", "prop": "speed", "to": "$accelAmount", "frames": "$accelFrames", "relative": true}
            ]},
            {"control": "Line", "count": "$lineCount", "prop": "speed", "from": "$lineSpeedFrom", "to": "$lineSpeedTo"}
          ]},
          {"control": "Vanish"}
        ]},
        {"control": "NWay", "count": "$nwayCount", "angle": "$nwayArc", "speed": 0}
      ]},
      {"control": "Vanish"}
    ]},
    {
      "control": "Loop", "actions": [
        {"control": "Set", "prop": "speed", "value": "random.between($seedSpeedMin, $seedSpeedMax)"},
        {"control": "Set", "prop": "direction", "value": "90 + random.angle(4)"},
        {"control": "Fire", "angle": 0, "speed": 0},
        {"control": "Wait", "frames": "$volleyDelay"},
        {"control": "Set", "prop": "speed", "value": "random.between($seedSpeedMin, $seedSpeedMax)"},
        {"control": "Set", "prop": "direction", "value": "270 + random.angle(4)"},
        {"control": "Fire", "angle": 0, "speed": 0},
        {"control": "Wait", "frames": "$volleyDelay"}
      ]
    }
  ]
}
